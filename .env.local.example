# ─── Sanity ──────────────────────────────────────────────────────────────────
# Get these from https://sanity.io/manage → your project → API

# Your Sanity project ID (found in sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here

# Dataset name — almost always "production"
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: only needed if you use draft preview or want to query unpublished content
# Create a token at sanity.io/manage → your project → API → Tokens
# SANITY_API_READ_TOKEN=your_token_here
